---
interface Props {
  href: string;
  title: string;
  tagline: string;
  date: Date;
  readTime: number;
  tags: string[];
  featured?: boolean;
}

const { href, title, tagline, date, readTime, tags, featured = false } = Astro.props;
const dateStr = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<a
  href={href}
  class:list={[
    "block group rounded-lg border bg-surface/40 p-6 transition-all hover:border-accent/50 hover:bg-surface no-underline",
    featured ? "border-accent/30" : "border-border",
  ]}
>
  <div class="flex items-center gap-3 text-xs text-muted mb-3">
    <time datetime={date.toISOString()}>{dateStr}</time>
    <span>·</span>
    <span>{readTime} min</span>
    {featured && <span class="ml-auto pill-accent">Featured</span>}
  </div>
  <h3 class="text-lg font-semibold tracking-tight text-ink group-hover:text-accent transition-colors">
    {title}
  </h3>
  <p class="text-sm text-muted mt-2 leading-relaxed">{tagline}</p>
  <div class="flex flex-wrap gap-2 mt-4">
    {tags.map((tag) => <span class="pill">{tag}</span>)}
  </div>
</a>
