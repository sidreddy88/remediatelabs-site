---
interface Metric {
  label: string;
  value: string;
  detail?: string;
}

const metrics: Metric[] = [
  { label: "Agent pipeline", value: "~6 min", detail: "from detected event to fix-PR" },
  { label: "Avg MTTR", value: "38 min", detail: "detection to merged fix" },
  { label: "CI pass rate", value: "100%", detail: "sandbox passes on first run" },
];
---

<section class="container-wide py-12 border-y border-border">
  <div class="grid grid-cols-3 gap-8">
    {metrics.map((m) => (
      <div>
        <p class="text-xs uppercase tracking-wider text-muted">{m.label}</p>
        <p class="text-3xl sm:text-4xl font-semibold text-ink mt-2 tracking-tight">{m.value}</p>
        {m.detail && <p class="text-xs text-muted mt-1">{m.detail}</p>}
      </div>
    ))}
  </div>
  <p class="text-xs text-muted mt-6">
    Numbers refresh from <code class="text-accent">scripts/measure_mttr.py</code> against the live demo DB.
    See <a href="/projects/agent-platform#metrics">the methodology</a> for how each is computed.
  </p>
</section>
