---
import { getCollection } from "astro:content";

interface Props {
  series: string;
  seriesPart: number;
  currentSlug: string;
}

const { series, seriesPart, currentSlug } = Astro.props;

const allPosts = await getCollection("blog");
const seriesPosts = allPosts
  .filter((p) => p.data.series === series && p.data.seriesPart != null)
  .sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0));

const total = seriesPosts.length;
const currentIndex = seriesPosts.findIndex((p) => p.slug === currentSlug);
const prev = currentIndex > 0 ? seriesPosts[currentIndex - 1] : null;
const next = currentIndex < total - 1 ? seriesPosts[currentIndex + 1] : null;

const seriesSlug = series.toLowerCase().replace(/\s+/g, "-");
---

<div class="not-prose mb-10 rounded-lg border border-border bg-surface px-5 py-4">
  <div class="flex items-center justify-between gap-4 flex-wrap">
    <div>
      <p class="text-xs uppercase tracking-wider text-muted mb-1">Series</p>
      <a
        href={`/blog/series/${seriesSlug}`}
        class="text-sm font-medium text-accent hover:underline no-underline"
      >
        {series}
      </a>
      <span class="text-xs text-muted ml-2">Part {seriesPart} of {total}</span>
    </div>
    <div class="flex gap-4 text-sm">
      {prev && (
        <a
          href={`/blog/${prev.slug}`}
          class="text-muted hover:text-ink no-underline transition-colors"
        >
          ← Part {prev.data.seriesPart}
        </a>
      )}
      {next && (
        <a
          href={`/blog/${next.slug}`}
          class="text-muted hover:text-ink no-underline transition-colors"
        >
          Part {next.data.seriesPart} →
        </a>
      )}
    </div>
  </div>

  <div class="mt-3 flex gap-1">
    {seriesPosts.map((p) => (
      <a
        href={`/blog/${p.slug}`}
        title={`Part ${p.data.seriesPart}: ${p.data.title}`}
        class={[
          "h-1 flex-1 rounded-full transition-colors no-underline",
          p.slug === currentSlug ? "bg-accent" : "bg-border hover:bg-muted",
        ].join(" ")}
      />
    ))}
  </div>
</div>
