---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "Remediate Labs — autonomous incident remediation for production systems",
  description = "An agent platform that detects production errors, diagnoses root causes, and opens fix PRs in single-digit minutes. Engineering blog and architecture deep-dives.",
  ogImage = "/og-image.png",
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const baseJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Remediate Labs",
    url: "https://remediatelabs.io",
    description,
    publisher: {
      "@type": "Person",
      name: "Siddharth Sukumar",
      url: "https://remediatelabs.io/about",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Siddharth Sukumar",
    url: "https://remediatelabs.io/about",
    sameAs: [
      "https://github.com/sidreddy88",
      "https://remediatelabs.io",
    ],
    jobTitle: "AI Engineer",
    description: "Builds production-grade agent systems. Currently working on Remediate Labs.",
  },
];

const allJsonLd = jsonLd
  ? [...baseJsonLd, ...(Array.isArray(jsonLd) ? jsonLd : [jsonLd])]
  : baseJsonLd;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Remediate Labs — Engineering Blog"
      href="/rss.xml"
    />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    {allJsonLd.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
