---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogCard from "../../../components/BlogCard.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const seriesNames = [
    ...new Set(posts.map((p) => p.data.series).filter(Boolean)),
  ] as string[];

  return seriesNames.map((series) => ({
    params: { series: series.toLowerCase().replace(/\s+/g, "-") },
    props: { seriesName: series },
  }));
}

const { seriesName } = Astro.props;

const allPosts = await getCollection("blog");
const posts = allPosts
  .filter((p) => p.data.series === seriesName)
  .sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0));
---

<BaseLayout
  title={`${seriesName} — Remediate Labs`}
  description={`A ${posts.length}-part series on ${seriesName.toLowerCase()}.`}
>
  <section class="container-wide pt-16 pb-8">
    <a href="/blog" class="text-xs text-muted hover:text-ink transition-colors">← All posts</a>
    <p class="text-xs uppercase tracking-wider text-muted mt-6 mb-2">Series</p>
    <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight text-ink leading-tight">
      {seriesName}
    </h1>
    <p class="text-muted text-lg mt-4">{posts.length} parts</p>
  </section>

  <section class="container-wide pb-20">
    <div class="flex flex-col gap-4">
      {posts.map((post) => (
        <div class="flex gap-5 items-start">
          <span class="text-2xl font-semibold text-border tabular-nums w-8 shrink-0 mt-1">
            {String(post.data.seriesPart).padStart(2, "0")}
          </span>
          <div class="flex-1">
            <BlogCard
              href={`/blog/${post.slug}`}
              title={post.data.title}
              tagline={post.data.tagline}
              date={post.data.date}
              readTime={post.data.readTime}
              tags={post.data.tags}
              featured={post.data.featured}
            />
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
