---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import MetricsBlock from "../components/MetricsBlock.astro";
import BlogCard from "../components/BlogCard.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const featured = posts.find((p) => p.data.featured);
const recent = posts.filter((p) => p.slug !== featured?.slug).slice(0, 3);

const howItWorks = [
  {
    n: "01",
    title: "Detect",
    body: "CloudWatch alarms fire on production errors and POST to a webhook. Push-based — no polling load on the production server.",
  },
  {
    n: "02",
    title: "Triage",
    body: "Haiku-class classifier filters real incidents from noise and duplicates. Ground truth from a 100-case golden dataset.",
  },
  {
    n: "03",
    title: "Diagnose",
    body: "Diagnosis agent grounds every claim against the actual repo via GitHub Code Search. No fabricated function names.",
  },
  {
    n: "04",
    title: "Fix",
    body: "Fix-generation agent writes a patch, runs it in a Docker sandbox against the real test suite, retries up to 3× on failure.",
  },
  {
    n: "05",
    title: "Approve",
    body: "HIGH/CRITICAL actions queue for human approval before merging. Approvals also feed an RLHF preference dataset.",
  },
];
---

<BaseLayout>
  <Hero />
  <MetricsBlock />

  <section class="container-wide py-20">
    <div class="flex items-baseline justify-between mb-10">
      <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight text-ink">How it works</h2>
      <a href="/projects/agent-platform" class="text-sm text-muted hover:text-ink">Architecture deep-dive →</a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-6">
      {howItWorks.map((step) => (
        <div class="rounded-lg border border-border bg-surface/40 p-5">
          <p class="text-xs font-mono text-accent">{step.n}</p>
          <h3 class="text-base font-semibold text-ink mt-2">{step.title}</h3>
          <p class="text-sm text-muted mt-2 leading-relaxed">{step.body}</p>
        </div>
      ))}
    </div>
  </section>

  {featured && (
    <section class="container-wide py-12">
      <div class="rounded-xl border border-accent/30 bg-gradient-to-br from-accent/[0.04] to-transparent p-8 sm:p-12">
        <div class="flex items-center gap-3 text-xs text-accent uppercase tracking-wider mb-3">
          <span>Featured post</span>
        </div>
        <a href={`/blog/${featured.slug}`} class="block group no-underline">
          <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight text-ink group-hover:text-accent transition-colors">
            {featured.data.title}
          </h2>
          <p class="text-muted mt-3 text-base sm:text-lg leading-relaxed max-w-3xl">
            {featured.data.tagline}
          </p>
          <p class="text-accent text-sm mt-5 group-hover:underline">Read the post →</p>
        </a>
      </div>
    </section>
  )}

  <section class="container-wide py-20">
    <div class="flex items-baseline justify-between mb-10">
      <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight text-ink">Recent writing</h2>
      <a href="/blog" class="text-sm text-muted hover:text-ink">All posts →</a>
    </div>
    <div class="grid md:grid-cols-3 gap-5">
      {recent.map((post) => (
        <BlogCard
          href={`/blog/${post.slug}`}
          title={post.data.title}
          tagline={post.data.tagline}
          date={post.data.date}
          readTime={post.data.readTime}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
