---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="RAG Playground — Remediate Labs"
  description="Interactive explorer for Code RAG and Incident RAG pipeline stages. Toggle function-boundary chunks, LLM descriptions, hybrid search, and cross-encoder re-ranking."
>
  <div class="min-h-screen bg-bg">
    <!-- header -->
    <div class="border-b border-border px-6 py-4 flex items-center justify-between">
      <div>
        <h1 class="text-lg font-semibold text-ink">RAG Pipeline Playground</h1>
        <p class="text-sm text-muted mt-0.5">Toggle techniques and see how rankings change in real time</p>
      </div>
      <!-- series tabs -->
      <div class="flex gap-1 bg-surface rounded-lg p-1 border border-border">
        <button id="tab-code" class="tab-btn active px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Code RAG</button>
        <button id="tab-incident" class="tab-btn px-4 py-1.5 rounded-md text-sm font-medium transition-colors">Incident RAG</button>
      </div>
    </div>

    <div class="flex" style="height: calc(100vh - 65px)">
      <!-- left sidebar -->
      <aside class="w-72 shrink-0 border-r border-border flex flex-col overflow-y-auto">

        <!-- query selector -->
        <div class="p-5 border-b border-border">
          <p class="text-xs font-mono text-muted uppercase tracking-wider mb-3">Query</p>
          <div id="query-buttons" class="space-y-1.5"></div>
        </div>

        <!-- pipeline toggles -->
        <div class="p-5 border-b border-border">
          <p class="text-xs font-mono text-muted uppercase tracking-wider mb-3">Pipeline Stages</p>
          <div class="space-y-3" id="toggle-panel"></div>
        </div>

        <!-- score formula -->
        <div class="p-5 flex-1">
          <p class="text-xs font-mono text-muted uppercase tracking-wider mb-3">Score Formula</p>
          <div id="formula-box" class="bg-surface rounded-lg border border-border p-3 font-mono text-xs text-muted leading-relaxed"></div>
        </div>
      </aside>

      <!-- main results panel -->
      <main class="flex-1 overflow-y-auto p-6">
        <!-- pipeline breadcrumb -->
        <div id="pipeline-bar" class="flex items-center gap-2 mb-6 flex-wrap"></div>

        <!-- results -->
        <div id="results-list" class="space-y-2.5"></div>
      </main>

      <!-- chunk preview panel -->
      <aside id="preview-panel" class="w-80 shrink-0 border-l border-border hidden flex-col overflow-y-auto">
        <div class="p-4 border-b border-border flex items-center justify-between">
          <p class="text-sm font-medium text-ink" id="preview-title">Chunk preview</p>
          <button id="close-preview" class="text-muted hover:text-ink text-lg leading-none">×</button>
        </div>
        <div class="p-4 font-mono text-xs overflow-auto" id="preview-content"></div>
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .tab-btn { color: #9aa1a9; }
  .tab-btn.active { background: #23272d; color: #e6e8eb; }
  .toggle-row { cursor: pointer; }
  .toggle-row:hover .toggle-label { color: #e6e8eb; }
  .toggle-switch {
    width: 36px; height: 20px; border-radius: 10px;
    background: #23272d; border: 1px solid #23272d;
    position: relative; transition: background 0.15s;
    flex-shrink: 0;
  }
  .toggle-switch.on { background: #6ee7b7; border-color: #6ee7b7; }
  .toggle-switch::after {
    content: ''; position: absolute; top: 2px; left: 2px;
    width: 14px; height: 14px; border-radius: 50%;
    background: #9aa1a9; transition: transform 0.15s, background 0.15s;
  }
  .toggle-switch.on::after { transform: translateX(16px); background: #0b0d10; }
  .result-row {
    border: 1px solid #23272d; border-radius: 10px;
    background: #13161a; transition: border-color 0.15s;
  }
  .result-row.target { border-color: #0f7a4f; }
  .result-row.target-rank1 { border-color: #6ee7b7; }
  .result-row:hover { border-color: #6ee7b7; cursor: pointer; }
  .rank-badge {
    width: 28px; height: 28px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 600; flex-shrink: 0;
  }
  .rank-1 { background: #6ee7b7; color: #0b0d10; }
  .rank-2 { background: #23272d; color: #e6e8eb; }
  .rank-3 { background: #23272d; color: #e6e8eb; }
  .rank-other { background: #13161a; border: 1px solid #23272d; color: #9aa1a9; }
  .score-bar-bg { background: #23272d; border-radius: 3px; height: 5px; overflow: hidden; }
  .score-bar-fill { height: 100%; border-radius: 3px; transition: width 0.3s; }
  .pipe-step { display: flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 6px; font-size: 12px; }
  .pipe-step.active { background: #0f7a4f; color: #6ee7b7; }
  .pipe-step.inactive { background: #13161a; border: 1px solid #23272d; color: #9aa1a9; }
  .pipe-arrow { color: #23272d; font-size: 14px; }
  @keyframes rankSlide {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .result-row { animation: rankSlide 0.2s ease-out; }
</style>

