  q4: { // "file not found when copying object in S3" — nosuchkey rank 1 by vec (0.5228 from blog)
    nosuchkey:   [0.52, 0.50, -0.35],  // vec=0.5228 ✓, ce=-0.35 ✓; 4/8 tokens (when,object,in,s3)
    typeerror:   [0.20, 0.25, -3.10],  // 2/8 tokens (when,in)
    syntaxerror: [0.16, 0.13, -4.80],  // 1/8 tokens (in)
    filenotfound:[0.48, 0.88, +6.80],  // vec was 0.60 (wrong—ranked above nosuchkey); 7/8 tokens (file,not,found,when,copying,in,s3)
    timeout:     [0.31, 0.25, +1.20],  // 2/8 tokens (in,s3)
  },
};

const INCIDENT_QUERIES = [
  { id: 'q1', text: 'classifyFields json parse error openai', label: 'Classification failure' },
  { id: 'q2', text: 'publish_decision undefined classification', label: 'Undefined property' },
  { id: 'q3', text: 'S3 NoSuchKey copy delete missing key', label: 'S3 key error' },
  { id: 'q4', text: 'file not found when copying object in S3', label: 'Vocabulary mismatch' },
];

const INCIDENT_TOGGLES = [
  { id: 'hybrid', label: 'Hybrid search', description: 'Mix vector + BM25 lexical. Rewards exact token matches like error codes and identifiers.' },
  { id: 'ce', label: 'Cross-encoder re-ranking', description: 'Re-score top-20 candidates with (query, doc) pairs. 30× wider score spread than vector alone.' },
];

// ─── STATE ────────────────────────────────────────────────────────────────────

let series = 'code';
let state = {
  code: { query: 'q4', fn: false, desc: false, hybrid: false, ce: false },
  incident: { query: 'q3', hybrid: false, ce: false },
};

// ─── SCORE COMPUTATION ────────────────────────────────────────────────────────

function computeCodeScores() {
  const s = state.code;
  const queryScores = CODE_SCORES[s.query];
  // Line-based mode shows split chunks (move_441, move_481); fn-boundary mode shows single move chunk
  const chunks = CODE_CHUNKS.filter(c => s.fn ? !c.lineOnly : !c.fnOnly);
  const results = chunks.map(chunk => {
    const [vecLine, vecFn, vecEnriched, lexNodesc, lexWithdesc, ceScore] = queryScores[chunk.id];

    const vecScore = s.desc ? vecEnriched : (s.fn ? vecFn : vecLine);
    const lexScore = s.desc ? lexWithdesc : lexNodesc;
    const hybridScore = s.hybrid ? (0.7 * vecScore + 0.3 * lexScore) : vecScore;
    const finalScore = s.ce ? ceScore : hybridScore;

    return {
      chunk,
      vecScore,
      lexScore,
      hybridScore,
      ceScore,
      finalScore,
      isHybrid: s.hybrid,
      isCE: s.ce,
    };
  });

  results.sort((a, b) => b.finalScore - a.finalScore);
  results.forEach((r, i) => { r.rank = i + 1; });
  return results;
}

function computeIncidentScores() {
  const s = state.incident;
  const queryScores = INCIDENT_SCORES[s.query];
  const results = INCIDENT_CHUNKS.map(chunk => {
    const [vecScore, lexScore, ceScore] = queryScores[chunk.id];
    const hybridScore = 0.7 * vecScore + 0.3 * lexScore;
    const baseScore = s.hybrid ? hybridScore : vecScore;
    const finalScore = s.ce ? ceScore : baseScore;
    return { chunk, vecScore, lexScore, hybridScore, ceScore, finalScore, isCE: s.ce };
  });
  results.sort((a, b) => b.finalScore - a.finalScore);
  results.forEach((r, i) => { r.rank = i + 1; });
  return results;
}

// ─── RENDER ───────────────────────────────────────────────────────────────────

function scoreColor(score, isCE) {
  if (isCE) {
    if (score > 6) return '#6ee7b7';
    if (score > 2) return '#86efac';
    if (score > 0) return '#fbbf24';
    return '#f87171';
  }
  if (score > 0.65) return '#6ee7b7';
  if (score > 0.45) return '#86efac';
  if (score > 0.30) return '#fbbf24';
  return '#f87171';
}

function fmtScore(score, isCE) {
  if (isCE) return (score >= 0 ? '+' : '') + score.toFixed(2);
  return score.toFixed(4);
}

function barWidth(score, isCE) {
  if (isCE) return Math.min(100, Math.max(2, (score + 12) / 22 * 100));
  return Math.min(100, Math.max(2, score * 100));
}

function renderResults(results) {
  const el = document.getElementById('results-list');
  el.innerHTML = '';

  const label = series === 'code'
    ? (state.code.ce ? 'CE score' : state.code.hybrid ? 'Hybrid score' : 'Vector score')
    : (state.incident.ce ? 'CE score' : state.incident.hybrid ? 'Hybrid score' : 'Vector score');

  const isCE = series === 'code' ? state.code.ce : state.incident.ce;

  results.slice(0, 6).forEach((r) => {
    const isTarget = r.chunk.isTarget;
    const isRank1 = r.rank === 1;
    const borderClass = isTarget && isRank1 ? 'target-rank1' : isTarget ? 'target' : '';

    const scoreBreakdown = buildScoreBreakdown(r);

    const div = document.createElement('div');
    div.className = `result-row ${borderClass} p-4`;
    div.innerHTML = `
      <div class="flex items-start gap-3">
        <div class="rank-badge rank-${Math.min(r.rank, 99)} ${r.rank > 3 ? 'rank-other' : ''}">${r.rank}</div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="font-mono text-sm ${isTarget ? 'text-accent font-semibold' : 'text-ink'}">${isTarget ? 'Target ' : ''}${r.chunk.name}</span>
            <span class="text-xs font-mono text-muted ml-auto">rank ${r.rank}</span>
          </div>
          ${scoreBreakdown}
          <div class="mt-2 score-bar-bg">
            <div class="score-bar-fill" style="width:${barWidth(r.finalScore, isCE)}%; background:${scoreColor(r.finalScore, isCE)}"></div>
          </div>
          <div class="flex items-center justify-between mt-1">
            <span class="text-xs text-muted">${label}</span>
            <span class="font-mono text-xs font-semibold" style="color:${scoreColor(r.finalScore, isCE)}">${fmtScore(r.finalScore, isCE)}</span>
          </div>
        </div>
        <button class="text-muted hover:text-accent text-xs shrink-0 mt-1 font-mono" data-chunk="${r.chunk.id}">view →</button>
      </div>
    `;
    div.querySelector('[data-chunk]').addEventListener('click', (e) => {
      e.stopPropagation();
      showPreview(r.chunk);
    });
    el.appendChild(div);
  });
}

function buildScoreBreakdown(r) {
  if (series === 'code') {
    const s = state.code;
    if (s.ce) {
      return `<div class="flex gap-3 text-xs text-muted mt-1">
        <span>vec <span class="font-mono text-ink">${r.vecScore.toFixed(3)}</span></span>
        ${s.hybrid ? `<span>lex <span class="font-mono text-ink">${(r.lexScore).toFixed(2)}</span></span>
        <span>hybrid <span class="font-mono text-ink">${r.hybridScore.toFixed(3)}</span></span>` : ''}
        <span class="text-accent font-semibold">CE ${fmtScore(r.ceScore, true)}</span>
      </div>`;
    }
    if (s.hybrid) {
      return `<div class="flex gap-3 text-xs text-muted mt-1">
        <span>vec <span class="font-mono text-ink">${r.vecScore.toFixed(3)}</span></span>
        <span>lex <span class="font-mono text-ink">${r.lexScore.toFixed(2)}</span></span>
        <span class="text-ink">= 0.7×${r.vecScore.toFixed(3)} + 0.3×${r.lexScore.toFixed(2)}</span>
      </div>`;
    }
    return '';
  } else {
    const s = state.incident;
    if (s.ce) {
      return `<div class="flex gap-3 text-xs text-muted mt-1">
        <span>vec <span class="font-mono text-ink">${r.vecScore.toFixed(4)}</span></span>
        <span class="text-accent font-semibold">CE ${fmtScore(r.ceScore, true)}</span>
      </div>`;
    }
    if (s.hybrid) {
      return `<div class="flex gap-3 text-xs text-muted mt-1">
        <span>vec <span class="font-mono text-ink">${r.vecScore.toFixed(4)}</span></span>
        <span>lex <span class="font-mono text-ink">${r.lexScore.toFixed(2)}</span></span>
        <span class="text-ink">= 0.7×${r.vecScore.toFixed(4)} + 0.3×${r.lexScore.toFixed(2)}</span>
      </div>`;
    }
    return '';
  }
}

function renderPipelineBar() {
  const bar = document.getElementById('pipeline-bar');
  bar.innerHTML = '';

  const steps = series === 'code'
    ? [
        { label: '50-line chunks', active: !state.code.fn },
        { label: 'Function boundaries', active: state.code.fn },
        { label: 'LLM descriptions', active: state.code.desc },
        { label: 'Hybrid search', active: state.code.hybrid },
        { label: 'Cross-encoder', active: state.code.ce },
      ]
    : [
        { label: 'Vector search', active: true },
        { label: 'Hybrid search', active: state.incident.hybrid },
        { label: 'Cross-encoder', active: state.incident.ce },
      ];

  steps.forEach((step, i) => {
    if (i > 0) {
      const arrow = document.createElement('span');
      arrow.className = 'pipe-arrow';
      arrow.textContent = '→';
      bar.appendChild(arrow);
    }
    const el = document.createElement('div');
    el.className = `pipe-step ${step.active ? 'active' : 'inactive'}`;
    el.textContent = step.label;
    bar.appendChild(el);
  });
}

function renderFormula() {
  const box = document.getElementById('formula-box');
  if (series === 'code') {
    const s = state.code;
    const lines = [];
    const vecBase = s.fn ? (s.desc ? 'vec(fn+desc)' : 'vec(fn)') : (s.desc ? 'vec(line+desc)' : 'vec(line)');
    if (s.hybrid && s.ce) {
      lines.push(`hybrid = 0.7 × ${vecBase}`, `      + 0.3 × lex`, ``, `final = CE(query, doc)`);
    } else if (s.hybrid) {
      lines.push(`final = 0.7 × ${vecBase}`, `      + 0.3 × lex`);
    } else if (s.ce) {
      lines.push(`final = CE(query, doc)`);
    } else {
      lines.push(`final = ${vecBase}`);
    }
    box.textContent = lines.join('\n');
  } else {
    const s = state.incident;
    if (s.ce) {
      box.textContent = 'stage 1: vector → top 20\nstage 2: CE(query, doc)\n        → re-sort → top 3';
    } else if (s.hybrid) {
      box.textContent = 'final = 0.7 × vec\n      + 0.3 × lex';
    } else {
      box.textContent = 'final = cosine(q, doc)';
    }
  }
}

function renderQueryButtons() {
  const container = document.getElementById('query-buttons');
  container.innerHTML = '';
  const queries = series === 'code' ? CODE_QUERIES : INCIDENT_QUERIES;
  const activeQ = series === 'code' ? state.code.query : state.incident.query;
  queries.forEach(q => {
    const btn = document.createElement('button');
    const isActive = q.id === activeQ;
    btn.className = `w-full text-left px-3 py-2.5 rounded-lg border text-xs transition-colors ${
      isActive ? 'border-accent/40 bg-accent/10 text-accent' : 'border-border text-muted hover:border-accent/30 hover:text-ink'
    }`;
    btn.innerHTML = `<div class="font-medium mb-0.5">${q.label}</div><div class="font-mono opacity-80 break-all">"${q.text}"</div>`;
    btn.addEventListener('click', () => {
      if (series === 'code') state.code.query = q.id;
      else state.incident.query = q.id;
      update();
    });
    container.appendChild(btn);
  });
}

function renderToggles() {
  const panel = document.getElementById('toggle-panel');
  panel.innerHTML = '';
  const toggles = series === 'code' ? CODE_TOGGLES : INCIDENT_TOGGLES;

  toggles.forEach(t => {
    const isOn = series === 'code' ? state.code[t.id] : state.incident[t.id];
    const row = document.createElement('div');
    row.className = 'toggle-row';
    row.innerHTML = `
      <div class="flex items-center justify-between gap-2 mb-0.5">
        <span class="toggle-label text-sm font-medium ${isOn ? 'text-ink' : 'text-muted'}">${t.label}</span>
        <div class="toggle-switch ${isOn ? 'on' : ''}"></div>
      </div>
      <p class="text-xs text-muted leading-relaxed">${t.description}</p>
    `;
    row.addEventListener('click', () => {
      if (series === 'code') state.code[t.id] = !state.code[t.id];
      else state.incident[t.id] = !state.incident[t.id];
      update();
    });
    panel.appendChild(row);
  });
}

function showPreview(chunk) {
  const panel = document.getElementById('preview-panel');
  const content = document.getElementById('preview-content');
  const title = document.getElementById('preview-title');
  panel.classList.remove('hidden');
  panel.classList.add('flex');
  title.textContent = chunk.name;

  const s = state.code;
  const useFn = s.fn;
  const useDesc = s.desc;

  let html = '';
  if (series === 'code') {
    const isLineChunk = chunk.lineOnly;
    const codeText = (!isLineChunk && useFn) ? chunk.fnCode : chunk.linePreview;
    const chunkLabel = isLineChunk ? '✗ Line-based chunk (50-line window)' : (useFn ? '✓ Function-boundary chunk' : '✗ Line-based chunk (50-line window)');
    html += `<div class="mb-3"><p class="text-muted text-xs mb-1.5">${chunkLabel}</p><pre class="text-accent leading-relaxed overflow-x-auto whitespace-pre-wrap">${escHtml(codeText)}</pre></div>`;
    if (useDesc && chunk.description) {
      html += `<div class="border-t border-border pt-3 mt-3"><p class="text-muted text-xs mb-1.5">✓ LLM-generated description</p><p class="text-ink leading-relaxed">${escHtml(chunk.description)}</p></div>`;
    } else if (!useDesc) {
      html += `<div class="border-t border-border pt-3 mt-3"><p class="text-muted text-xs">✗ No description (toggle LLM descriptions to add)</p></div>`;
    }
  } else {
    html += `<pre class="text-accent leading-relaxed whitespace-pre-wrap">${escHtml(chunk.preview)}</pre>`;
  }

  content.innerHTML = html;
}

function escHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function update() {
  const results = series === 'code' ? computeCodeScores() : computeIncidentScores();
  renderQueryButtons();
  renderToggles();
  renderPipelineBar();
  renderFormula();
  renderResults(results);
  // Close preview on state change
  document.getElementById('preview-panel').classList.add('hidden');
  document.getElementById('preview-panel').classList.remove('flex');
}

// ─── INIT ─────────────────────────────────────────────────────────────────────

document.getElementById('tab-code').addEventListener('click', () => {
  series = 'code';
  document.getElementById('tab-code').classList.add('active');
  document.getElementById('tab-incident').classList.remove('active');
  update();
});

document.getElementById('tab-incident').addEventListener('click', () => {
  series = 'incident';
  document.getElementById('tab-incident').classList.add('active');
  document.getElementById('tab-code').classList.remove('active');
  update();
});

document.getElementById('close-preview').addEventListener('click', () => {
  document.getElementById('preview-panel').classList.add('hidden');
  document.getElementById('preview-panel').classList.remove('flex');
});

update();
</script>
</BaseLayout>
