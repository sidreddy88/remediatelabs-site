// Scores: [vecLine, vecFn, vecEnriched, lexNodesc, lexWithdesc, ceScore]
// vecEnriched = vecFn + descBoost (desc can help or hurt slightly)
// hybridScore = 0.7 * vecEnriched + 0.3 * lexWithdesc
// Documented values from blog posts are marked ✓

// move_441 / move_481 are line-only chunks — only vecLine is used (fnOnly `move` handles fn-boundary stages)
// vecLine values set so line-based rankings match blog: Q1→r1, Q2→r3/r4, Q3→r4, Q4→not found
const CODE_SCORES = {
  q1: { // "moveAndRemoveFileFromS3" — chunk_441 r1 ✓, chunk_481 not in top 5 ✓
    move_441:  [0.560, 0, 0, 0, 0, 0],
    move_481:  [0.290, 0, 0, 0, 0, 0],
    move:      [0.000, 0.709, 0.675, 1.00, 1.00, +9.81], // ✓ fn-boundary stages
    upload:    [0.390, 0.430, 0.425, 0.25, 0.25, +0.85],
    dimensions:[0.325, 0.360, 0.355, 0.00, 0.00, -3.20],
    fix:       [0.300, 0.335, 0.330, 0.00, 0.00, -3.80],
    thumbnail: [0.305, 0.345, 0.340, 0.25, 0.25, -2.90],
    delete:    [0.355, 0.395, 0.388, 0.50, 0.50, +1.20],
  },
  q2: { // "copy S3 object then delete source" — chunk_441 r3 (0.5035) ✓, chunk_481 r4 (0.4353) ✓
    move_441:  [0.503, 0, 0, 0, 0, 0], // r3 ✓
    move_481:  [0.435, 0, 0, 0, 0, 0], // r4 ✓ (blog score 0.4353)
    move:      [0.000, 0.572, 0.572, 1.00, 1.00, +9.14], // ✓
    upload:    [0.520, 0.465, 0.460, 0.40, 0.40, +1.30], // r2 in line-mode
    dimensions:[0.330, 0.370, 0.365, 0.20, 0.20, -2.80],
    fix:       [0.310, 0.348, 0.343, 0.20, 0.20, -3.40],
    thumbnail: [0.315, 0.355, 0.348, 0.40, 0.40, -1.90],
    delete:    [0.540, 0.425, 0.420, 0.80, 0.80, +2.10], // r1 in line-mode
  },
  q3: { // "S3 copyObject deleteObject bucket key" — chunk_441 r4 ✓, chunk_481 not in top 5 ✓
    move_441:  [0.502, 0, 0, 0, 0, 0], // r4 ✓
    move_481:  [0.310, 0, 0, 0, 0, 0], // r7 — not in top 5 ✓
    move:      [0.000, 0.597, 0.614, 1.00, 1.00, +9.43], // ✓ fn-boundary r2, enriched r2, hybrid r1
    upload:    [0.525, 0.455, 0.450, 0.20, 0.20, +0.60], // r2 in line-mode
    dimensions:[0.340, 0.380, 0.375, 0.20, 0.20, -2.50],
    fix:       [0.315, 0.353, 0.347, 0.20, 0.20, -3.10],
    thumbnail: [0.510, 0.362, 0.355, 0.20, 0.20, -2.60], // r3 in line-mode
    delete:    [0.535, 0.640, 0.640, 0.40, 0.40, +1.80], // r1 line ✓; fn-boundary r1 ✓; enriched r1 ✓
  },
  q4: { // "S3 NoSuchKey missing key error" — not found in all pre-hybrid stages ✓
    move_441:  [0.195, 0, 0, 0, 0, 0], // r6 — not in top 5 ✓
    move_481:  [0.190, 0, 0, 0, 0, 0], // r7 — not in top 5 ✓
    move:      [0.000, 0.200, 0.283, 0.60, 0.80, +8.31], // fn-boundary r6 (not in top 5) ✓; hybrid r3 ✓; CE r1 ✓
    upload:    [0.270, 0.255, 0.315, 0.40, 0.80, +2.14], // ✓ hybrid vec=0.3146, hybrid r1 ✓
    dimensions:[0.290, 0.245, 0.304, 0.40, 0.80, -1.83], // ✓ hybrid vec=0.3037, hybrid r2 ✓
    fix:       [0.265, 0.242, 0.282, 0.40, 0.80, -2.07], // hybrid vec=0.2823, hybrid r4 ✓
    thumbnail: [0.280, 0.240, 0.282, 0.40, 0.80, -2.31], // ✓ hybrid vec=0.2818, hybrid r5 ✓
    delete:    [0.260, 0.262, 0.265, 0.60, 0.80, -3.50], // not in hybrid top 5 ✓; not in CE top 5 ✓
  },
};

const CODE_QUERIES = [
  { id: 'q1', text: 'moveAndRemoveFileFromS3', label: 'Function name' },
  { id: 'q2', text: 'copy S3 object then delete source', label: 'Natural language' },
  { id: 'q3', text: 'S3 copyObject deleteObject bucket key', label: 'API call names' },
  { id: 'q4', text: 'S3 NoSuchKey missing key error', label: 'Incident vocabulary' },
];

const CODE_TOGGLES = [
  { id: 'fn', label: 'Function-boundary chunks', description: 'Isolate each function into its own chunk. Fixes dilution from 50-line windows.' },
  { id: 'desc', label: 'LLM-generated descriptions', description: 'Append a generated description to each chunk. Adds missing vocabulary (error types, intent).' },
  { id: 'hybrid', label: 'Hybrid search', description: 'Mix vector + lexical (BM25). Lexical rewards exact token matches like error codes.' },
  { id: 'ce', label: 'Cross-encoder re-ranking', description: 'Re-score top-20 candidates by running (query, doc) pairs through a cross-encoder model.' },
];

// ─── STATE ────────────────────────────────────────────────────────────────────

let state = { query: 'q4', fn: false, desc: false, hybrid: false, ce: false };

// ─── SCORE COMPUTATION ────────────────────────────────────────────────────────

function computeScores() {
  const s = state;
  const queryScores = CODE_SCORES[s.query];
  const chunks = CODE_CHUNKS.filter(c => s.fn ? !c.lineOnly : !c.fnOnly);
  const results = chunks.map(chunk => {
    const [vecLine, vecFn, vecEnriched, lexNodesc, lexWithdesc, ceScore] = queryScores[chunk.id];

    const vecScore = s.desc ? vecEnriched : (s.fn ? vecFn : vecLine);
    const lexScore = s.desc ? lexWithdesc : lexNodesc;
    const hybridScore = s.hybrid ? (0.7 * vecScore + 0.3 * lexScore) : vecScore;
    const finalScore = s.ce ? ceScore : hybridScore;

    return { chunk, vecScore, lexScore, hybridScore, ceScore, finalScore, isHybrid: s.hybrid, isCE: s.ce };
  });

  results.sort((a, b) => b.finalScore - a.finalScore);
  results.forEach((r, i) => { r.rank = i + 1; });
  return results;
}

// ─── RENDER ───────────────────────────────────────────────────────────────────

function scoreColor(score, isCE) {
  if (isCE) {
    if (score > 6) return '#6ee7b7';
    if (score > 2) return '#86efac';
    if (score > 0) return '#fbbf24';
    return '#f87171';
  }
  if (score > 0.65) return '#6ee7b7';
  if (score > 0.45) return '#86efac';
  if (score > 0.30) return '#fbbf24';
  return '#f87171';
}

function fmtScore(score, isCE) {
  if (isCE) return (score >= 0 ? '+' : '') + score.toFixed(2);
  return score.toFixed(4);
}

function barWidth(score, isCE) {
  if (isCE) return Math.min(100, Math.max(2, (score + 12) / 22 * 100));
  return Math.min(100, Math.max(2, score * 100));
}

function renderResults(results) {
  const el = document.getElementById('results-list');
  el.innerHTML = '';

  const label = state.ce ? 'CE score' : state.hybrid ? 'Hybrid score' : 'Vector score';
  const isCE = state.ce;

  results.slice(0, 6).forEach((r) => {
    const isTarget = r.chunk.isTarget;
    const isRank1 = r.rank === 1;
    const borderClass = isTarget && isRank1 ? 'target-rank1' : isTarget ? 'target' : '';
    const scoreBreakdown = buildScoreBreakdown(r);

    const div = document.createElement('div');
    div.className = `result-row ${borderClass} p-4`;
    div.innerHTML = `
      <div class="flex items-start gap-3">
        <div class="rank-badge rank-${Math.min(r.rank, 99)} ${r.rank > 3 ? 'rank-other' : ''}">${r.rank}</div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="font-mono text-sm ${isTarget ? 'text-accent font-semibold' : 'text-ink'}">${isTarget ? 'Target ' : ''}${r.chunk.name}</span>
            <span class="text-xs font-mono text-muted ml-auto">rank ${r.rank}</span>
          </div>
          ${scoreBreakdown}
          <div class="mt-2 score-bar-bg">
            <div class="score-bar-fill" style="width:${barWidth(r.finalScore, isCE)}%; background:${scoreColor(r.finalScore, isCE)}"></div>
          </div>
          <div class="flex items-center justify-between mt-1">
            <span class="text-xs text-muted">${label}</span>
            <span class="font-mono text-xs font-semibold" style="color:${scoreColor(r.finalScore, isCE)}">${fmtScore(r.finalScore, isCE)}</span>
          </div>
        </div>
        <button class="text-muted hover:text-accent text-xs shrink-0 mt-1 font-mono" data-chunk="${r.chunk.id}">view →</button>
      </div>
    `;
    div.querySelector('[data-chunk]').addEventListener('click', (e) => {
      e.stopPropagation();
      showPreview(r.chunk);
    });
    el.appendChild(div);
  });
}

function buildScoreBreakdown(r) {
  if (state.ce) {
    return `<div class="flex gap-3 text-xs text-muted mt-1">
      <span>vec <span class="font-mono text-ink">${r.vecScore.toFixed(3)}</span></span>
      ${state.hybrid ? `<span>lex <span class="font-mono text-ink">${r.lexScore.toFixed(2)}</span></span>
      <span>hybrid <span class="font-mono text-ink">${r.hybridScore.toFixed(3)}</span></span>` : ''}
      <span class="text-accent font-semibold">CE ${fmtScore(r.ceScore, true)}</span>
    </div>`;
  }
  if (state.hybrid) {
    return `<div class="flex gap-3 text-xs text-muted mt-1">
      <span>vec <span class="font-mono text-ink">${r.vecScore.toFixed(3)}</span></span>
      <span>lex <span class="font-mono text-ink">${r.lexScore.toFixed(2)}</span></span>
      <span class="text-ink">= 0.7×${r.vecScore.toFixed(3)} + 0.3×${r.lexScore.toFixed(2)}</span>
    </div>`;
  }
  return '';
}

function renderPipelineBar() {
  const bar = document.getElementById('pipeline-bar');
  bar.innerHTML = '';

  const steps = [
    { label: '50-line chunks', active: !state.fn },
    { label: 'Function boundaries', active: state.fn },
    { label: 'LLM descriptions', active: state.desc },
    { label: 'Hybrid search', active: state.hybrid },
    { label: 'Cross-encoder', active: state.ce },
  ];

  steps.forEach((step, i) => {
    if (i > 0) {
      const arrow = document.createElement('span');
      arrow.className = 'pipe-arrow';
      arrow.textContent = '→';
      bar.appendChild(arrow);
    }
    const el = document.createElement('div');
    el.className = `pipe-step ${step.active ? 'active' : 'inactive'}`;
    el.textContent = step.label;
    bar.appendChild(el);
  });
}

function renderFormula() {
  const box = document.getElementById('formula-box');
  const s = state;
  const lines = [];
  const vecBase = s.fn ? (s.desc ? 'vec(fn+desc)' : 'vec(fn)') : (s.desc ? 'vec(line+desc)' : 'vec(line)');
  if (s.hybrid && s.ce) {
    lines.push(`hybrid = 0.7 × ${vecBase}`, `      + 0.3 × lex`, ``, `final = CE(query, doc)`);
  } else if (s.hybrid) {
    lines.push(`final = 0.7 × ${vecBase}`, `      + 0.3 × lex`);
  } else if (s.ce) {
    lines.push(`final = CE(query, doc)`);
  } else {
    lines.push(`final = ${vecBase}`);
  }
  box.textContent = lines.join('\n');
}

function renderQueryButtons() {
  const container = document.getElementById('query-buttons');
  container.innerHTML = '';
  CODE_QUERIES.forEach(q => {
    const btn = document.createElement('button');
    const isActive = q.id === state.query;
    btn.className = `w-full text-left px-3 py-2.5 rounded-lg border text-xs transition-colors ${
      isActive ? 'border-accent/40 bg-accent/10 text-accent' : 'border-border text-muted hover:border-accent/30 hover:text-ink'
    }`;
    btn.innerHTML = `<div class="font-medium mb-0.5">${q.label}</div><div class="font-mono opacity-80 break-all">"${q.text}"</div>`;
    btn.addEventListener('click', () => {
      state.query = q.id;
      update();
    });
    container.appendChild(btn);
  });
}

function renderToggles() {
  const panel = document.getElementById('toggle-panel');
  panel.innerHTML = '';
  CODE_TOGGLES.forEach(t => {
    const isOn = state[t.id];
    const row = document.createElement('div');
    row.className = 'toggle-row';
    row.innerHTML = `
      <div class="flex items-center justify-between gap-2 mb-0.5">
        <span class="toggle-label text-sm font-medium ${isOn ? 'text-ink' : 'text-muted'}">${t.label}</span>
        <div class="toggle-switch ${isOn ? 'on' : ''}"></div>
      </div>
      <p class="text-xs text-muted leading-relaxed">${t.description}</p>
    `;
    row.addEventListener('click', () => {
      state[t.id] = !state[t.id];
      update();
    });
    panel.appendChild(row);
  });
}

function showPreview(chunk) {
  const panel = document.getElementById('preview-panel');
  const content = document.getElementById('preview-content');
  const title = document.getElementById('preview-title');
  panel.classList.remove('hidden');
  panel.classList.add('flex');
  title.textContent = chunk.name;

  const isLineChunk = chunk.lineOnly;
  const codeText = (!isLineChunk && state.fn) ? chunk.fnCode : chunk.linePreview;
  const chunkLabel = isLineChunk ? '✗ Line-based chunk (50-line window)' : (state.fn ? '✓ Function-boundary chunk' : '✗ Line-based chunk (50-line window)');

  let html = `<div class="mb-3"><p class="text-muted text-xs mb-1.5">${chunkLabel}</p><pre class="text-accent leading-relaxed overflow-x-auto whitespace-pre-wrap">${escHtml(codeText)}</pre></div>`;
  if (state.desc && chunk.description) {
    html += `<div class="border-t border-border pt-3 mt-3"><p class="text-muted text-xs mb-1.5">✓ LLM-generated description</p><p class="text-ink leading-relaxed">${escHtml(chunk.description)}</p></div>`;
  } else if (!state.desc) {
    html += `<div class="border-t border-border pt-3 mt-3"><p class="text-muted text-xs">✗ No description (toggle LLM descriptions to add)</p></div>`;
  }

  content.innerHTML = html;
}

function escHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function update() {
  renderQueryButtons();
  renderToggles();
  renderPipelineBar();
  renderFormula();
  renderResults(computeScores());
  document.getElementById('preview-panel').classList.add('hidden');
  document.getElementById('preview-panel').classList.remove('flex');
}

// ─── INIT ─────────────────────────────────────────────────────────────────────

document.getElementById('close-preview').addEventListener('click', () => {
  document.getElementById('preview-panel').classList.add('hidden');
  document.getElementById('preview-panel').classList.remove('flex');
});

update();
</script>
</BaseLayout>
