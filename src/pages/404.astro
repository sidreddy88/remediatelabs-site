---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Not found — Remediate Labs" description="That page doesn't exist.">
  <section class="container-prose pt-24 pb-16">
    <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted">Error 404</p>
    <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight text-ink mt-3">
      That page doesn't exist.
    </h1>
    <p class="text-muted text-lg mt-4 leading-relaxed">
      The link is broken, the post moved, or it never existed. Try one of these instead.
    </p>

    <div class="grid sm:grid-cols-2 gap-3 mt-10 not-prose">
      <a href="/" class="rounded-lg border border-border bg-surface/40 p-5 hover:border-accent transition-colors no-underline">
        <p class="text-sm text-muted">Start here</p>
        <p class="text-ink font-medium mt-1">Remediate Labs home</p>
      </a>
      <a href="/projects/agent-platform" class="rounded-lg border border-border bg-surface/40 p-5 hover:border-accent transition-colors no-underline">
        <p class="text-sm text-muted">Architecture deep-dive</p>
        <p class="text-ink font-medium mt-1">agent-platform →</p>
      </a>
      <a href="/blog" class="rounded-lg border border-border bg-surface/40 p-5 hover:border-accent transition-colors no-underline">
        <p class="text-sm text-muted">All posts</p>
        <p class="text-ink font-medium mt-1">Engineering blog</p>
      </a>
      <a href="/about" class="rounded-lg border border-border bg-surface/40 p-5 hover:border-accent transition-colors no-underline">
        <p class="text-sm text-muted">Who's behind this</p>
        <p class="text-ink font-medium mt-1">About →</p>
      </a>
    </div>

    <div class="mt-16 not-prose">
      <h2 class="text-xs uppercase tracking-wider text-muted mb-5">Recent posts</h2>
      <ul class="space-y-4">
        {posts.map((p) => (
          <li>
            <a href={`/blog/${p.slug}`} class="block group no-underline">
              <p class="text-ink group-hover:text-accent transition-colors">{p.data.title}</p>
              <p class="text-sm text-muted mt-1">{p.data.tagline}</p>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
